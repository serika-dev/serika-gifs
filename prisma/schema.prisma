generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  accountId     String    @unique // Links to serika-accounts
  username      String    @unique
  email         String    @unique
  avatar        String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  gifs          Gif[]
  collections   Collection[]
  favorites     Favorite[]
  apiKeys       ApiKey[]
  quotaRequests QuotaRequest[]
}

model Gif {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  description   String?
  url           String    // Backblaze URL (GIF)
  mp4Url        String?   // MP4 URL for video playback
  webmUrl       String?   // WebM URL for video playback (smaller, better quality)
  thumbnailUrl  String?   // Thumbnail URL
  width         Int
  height        Int
  fileSize      Int       // in bytes
  duration      Float?    // in seconds
  source        GifSource @default(UPLOAD)
  sourceId      String?   // Original ID from external source
  sourceUrl     String?   // Original URL from external source
  isPublic      Boolean   @default(true)
  views         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tags          TagOnGif[]
  favorites     Favorite[]
  collections   GifOnCollection[]

  @@index([userId])
  @@index([slug])
  @@index([source, sourceId])
}

enum GifSource {
  UPLOAD
  TENOR
  GIPHY
  KLIPY
}

model Tag {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  createdAt     DateTime  @default(now())

  gifs          TagOnGif[]

  @@index([slug])
}

model TagOnGif {
  gifId         String
  tagId         String
  gif           Gif       @relation(fields: [gifId], references: [id], onDelete: Cascade)
  tag           Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gifId, tagId])
}

model Collection {
  id            String    @id @default(cuid())
  name          String
  slug          String
  description   String?
  isPublic      Boolean   @default(true)
  isGlobal      Boolean   @default(false) // Staff-only: pinned to top as global category
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  gifs          GifOnCollection[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([isGlobal])
}

model GifOnCollection {
  gifId         String
  collectionId  String
  addedAt       DateTime  @default(now())
  gif           Gif       @relation(fields: [gifId], references: [id], onDelete: Cascade)
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([gifId, collectionId])
}

model Favorite {
  userId        String
  gifId         String
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gif           Gif       @relation(fields: [gifId], references: [id], onDelete: Cascade)

  @@id([userId, gifId])
}

model ApiKey {
  id            String         @id @default(cuid())
  name          String
  key           String         @unique
  tier          ApiKeyTier     @default(TIER_1)
  lastUsedAt    DateTime?
  createdAt     DateTime       @default(now())
  expiresAt     DateTime?
  
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotaRequests QuotaRequest[]

  @@index([key])
  @@index([userId])
}

enum ApiKeyTier {
  TIER_1  // 1k requests/hour (default)
  TIER_2  // 10k requests/hour (quota request required)
  TIER_3  // 100k requests/hour (quota request required)
  TIER_4  // 1M requests/hour (quota request required)
  TIER_5  // Unlimited (quota request required, admin keys auto-upgrade)
}

model ImportJob {
  id            String      @id @default(cuid())
  source        GifSource
  status        ImportStatus @default(PENDING)
  query         String?     // Search query if applicable
  totalItems    Int         @default(0)
  importedItems Int         @default(0)
  failedItems   Int         @default(0)
  error         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  @@index([status])
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model QuotaRequest {
  id            String            @id @default(cuid())
  requestedTier ApiKeyTier
  reason        String
  status        QuotaRequestStatus @default(PENDING)
  adminNote     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  resolvedAt    DateTime?

  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyId      String
  apiKey        ApiKey            @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

enum QuotaRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model DmcaRequest {
  id                String         @id @default(cuid())
  status            DmcaStatus     @default(PENDING)
  
  // Claimant info
  claimantName      String
  claimantEmail     String
  claimantCompany   String?
  
  // Claim details
  copyrightWork     String         // Description of original work
  infringingUrls    String[]       // Array of GIF URLs/slugs
  tagSlug           String?        // If claiming all GIFs under a tag
  statement         String         // Good faith statement
  signature         String         // Electronic signature
  
  // Processing
  adminNote         String?
  processedAt       DateTime?
  removedCount      Int            @default(0)
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
  @@index([claimantEmail])
}

enum DmcaStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  COUNTER_FILED
}
