generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  accountId     String    @unique // Links to serika-accounts
  username      String    @unique
  email         String    @unique
  avatar        String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  gifs          Gif[]
  collections   Collection[]
  favorites     Favorite[]
  apiKeys       ApiKey[]
}

model Gif {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  description   String?
  url           String    // Backblaze URL (GIF)
  mp4Url        String?   // MP4 URL for video playback
  webmUrl       String?   // WebM URL for video playback (smaller, better quality)
  thumbnailUrl  String?   // Thumbnail URL
  width         Int
  height        Int
  fileSize      Int       // in bytes
  duration      Float?    // in seconds
  source        GifSource @default(UPLOAD)
  sourceId      String?   // Original ID from external source
  sourceUrl     String?   // Original URL from external source
  isPublic      Boolean   @default(true)
  views         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tags          TagOnGif[]
  favorites     Favorite[]
  collections   GifOnCollection[]

  @@index([userId])
  @@index([slug])
  @@index([source, sourceId])
}

enum GifSource {
  UPLOAD
  TENOR
  GIPHY
  KLIPY
}

model Tag {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  createdAt     DateTime  @default(now())

  gifs          TagOnGif[]

  @@index([slug])
}

model TagOnGif {
  gifId         String
  tagId         String
  gif           Gif       @relation(fields: [gifId], references: [id], onDelete: Cascade)
  tag           Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gifId, tagId])
}

model Collection {
  id            String    @id @default(cuid())
  name          String
  slug          String
  description   String?
  isPublic      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  gifs          GifOnCollection[]

  @@unique([userId, slug])
  @@index([userId])
}

model GifOnCollection {
  gifId         String
  collectionId  String
  addedAt       DateTime  @default(now())
  gif           Gif       @relation(fields: [gifId], references: [id], onDelete: Cascade)
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([gifId, collectionId])
}

model Favorite {
  userId        String
  gifId         String
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gif           Gif       @relation(fields: [gifId], references: [id], onDelete: Cascade)

  @@id([userId, gifId])
}

model ApiKey {
  id            String    @id @default(cuid())
  name          String
  key           String    @unique
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime?
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
}

model ImportJob {
  id            String      @id @default(cuid())
  source        GifSource
  status        ImportStatus @default(PENDING)
  query         String?     // Search query if applicable
  totalItems    Int         @default(0)
  importedItems Int         @default(0)
  failedItems   Int         @default(0)
  error         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  @@index([status])
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
